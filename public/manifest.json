{
  "manifest_version": 3,
  "name": "Quillery — AI Prompt Manager",
  "version": "1.1.0",
  "description": "Organize, optimize and reuse your AI prompts — opens in a side panel so it stays open while you work.",
  "minimum_chrome_version": "120",
  "action": {
    "default_title": "Open Quillery"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "permissions": ["sidePanel"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
